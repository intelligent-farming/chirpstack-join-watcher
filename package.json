{
  "name": "@intelligent-farming/chirpstack-join-watcher",
  "version": "0.1.0",
  "description": "Listen to ChirpStack join requests and identify the likely vendor of unknown devices from the DevEUI OUI (and optional JoinEUI override map).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "files": [
    "dist/",
    "data/"
  ],
  "engines": {
    "node": ">=14"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "npm run build && node test/smoke.js",
    "docs": "typedoc && mv docs/README.md docs/api-doc.md",
    "build-ouis": "node scripts/build-ouis.js"
  },
  "dependencies": {
    "mqtt": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
