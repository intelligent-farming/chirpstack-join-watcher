{
  "name": "@intelligentfarming/chirpstack-join-watcher",
  "version": "0.1.0",
  "description": "Listen to ChirpStack join requests and identify the likely vendor of unknown devices from the DevEUI OUI (and optional JoinEUI override map).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "npm run build && node --test --test-reporter=spec test/smoke.js",
    "docs": "typedoc && mv docs/README.md docs/api-doc.md"
  },
  "dependencies": {
    "mqtt": "^5.5.0",
    "@intelligentfarming/oui-registry": "file:../oui-registry"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
