{
  "name": "@intelligent-farming/chirpstack-join-watcher",
  "version": "0.1.1",
  "description": "Listen to ChirpStack join requests and identify the likely vendor of unknown devices from the DevEUI OUI (and optional JoinEUI override map).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intelligent-farming/chirpstack-join-watcher.git"
  },
  "homepage": "https://github.com/intelligent-farming/chirpstack-join-watcher#readme",
  "bugs": {
    "url": "https://github.com/intelligent-farming/chirpstack-join-watcher/issues"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "npm run build && node --test --test-reporter=spec test/smoke.js",
    "docs": "typedoc && mv docs/README.md docs/api-doc.md"
  },
  "dependencies": {
    "mqtt": "^5.5.0",
    "@intelligent-farming/oui-registry": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
